## 민감정보 템플릿 — 이 파일을 복사하여 application-secrets.yml로 만드세요.
## cp application-secrets.yml.example application-secrets.yml

spring:
  datasource:
    hikari:
      jdbc-url: jdbc:oracle:thin:@<ORACLE_HOST>:<ORACLE_PORT>/<ORACLE_SID>
      username: <ORACLE_USERNAME>
      password: <ORACLE_PASSWORD>

clickhouse:
  datasource:
    hikari:
      jdbc-url: jdbc:ch://<CLICKHOUSE_HOST>:<CLICKHOUSE_PORT>/lighthouse
      username: <CLICKHOUSE_USERNAME>
      password: <CLICKHOUSE_PASSWORD>

app:
  cors:
    allowed-origins: <CORS_ORIGINS>
  init-admin:
    username: <ADMIN_USERNAME>
    password: <ADMIN_PASSWORD>
  jwt:
    secret: <JWT_SECRET_AT_LEAST_256_BITS>
    access-token-expiration: 3600000
    refresh-token-expiration: 604800000

websocket:
  allowed-origins: <WS_ORIGINS>

lighthouse:
  alert:
    slack:
      webhook-url: <SLACK_WEBHOOK_URL>
